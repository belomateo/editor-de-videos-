# === TRANSCRIPCIÓN (elegí UNA) ===
# Opción barata/gratis: Groq (console.groq.com). Si está, se usa esta.
GROQ_API_KEY=
# Opción estándar: OpenAI Whisper (platform.openai.com)
OPENAI_API_KEY=

# === ANÁLISIS IA (cortes, hooks, clips, captions) ===
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# === GOOGLE DRIVE (opcional, para el botón "Subir a Drive") ===
# Obtenelos corriendo: node scripts/get-google-token.mjs (ver README)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# ID de la carpeta destino en Drive (lo que aparece en la URL de la carpeta)
GOOGLE_DRIVE_FOLDER_ID=

# Carpeta de datos (en Railway montá un volumen acá)
DATA_DIR=./data
